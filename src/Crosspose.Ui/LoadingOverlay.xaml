<UserControl x:Class="Crosspose.Ui.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             IsHitTestVisible="True">
    <Grid Background="{DynamicResource OverlayBackdrop}">
        <Border Background="{DynamicResource OverlayCard}"
                CornerRadius="6"
                Padding="48,24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="440">
            <TextBlock Text="{Binding Message, ElementName=Root}"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource OverlayForeground}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
