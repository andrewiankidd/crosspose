<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Reusable GroupItem style for a ListView with CollectionViewSource grouping.
        Each group renders as a collapsible Expander with a bold name + item count badge.
        Uses DynamicResource so it responds to dark/light theme switches automatically.
        Usage:
            <ListView.GroupStyle>
                <GroupStyle ContainerStyle="{StaticResource GroupedListGroupContainerStyle}" />
            </ListView.GroupStyle>
    -->
    <Style x:Key="GroupedListGroupContainerStyle" TargetType="{x:Type GroupItem}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GroupItem}">
                    <Border BorderBrush="{DynamicResource BorderBrushColor}"
                            BorderThickness="0,0,0,1">
                        <Expander IsExpanded="True"
                                  Background="{DynamicResource PanelBackground}"
                                  Foreground="{DynamicResource TextPrimary}"
                                  Padding="4,3">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}"
                                               Foreground="{DynamicResource TextMuted}"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0" />
                                </StackPanel>
                            </Expander.Header>
                            <ItemsPresenter />
                        </Expander>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
