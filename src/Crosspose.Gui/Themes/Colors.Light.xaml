<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Base -->
    <SolidColorBrush x:Key="WindowBackground" Color="#F8F9FB" />
    <SolidColorBrush x:Key="PanelBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SidebarBackground" Color="#EAEAEA" />
    <SolidColorBrush x:Key="BorderBrushColor" Color="#D0D5DD" />
    <SolidColorBrush x:Key="TextPrimary" Color="#111827" />
    <SolidColorBrush x:Key="TextMuted" Color="#4B5563" />
    <SolidColorBrush x:Key="InputBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="InputBorder" Color="#D0D5DD" />

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonBackground" Color="#E5E7EB" />
    <SolidColorBrush x:Key="ButtonForeground" Color="#111827" />
    <SolidColorBrush x:Key="ButtonBorder" Color="#D0D5DD" />
    <SolidColorBrush x:Key="ButtonDisabledBackground" Color="#ECEEF1" />
    <SolidColorBrush x:Key="ButtonDisabledForeground" Color="#9CA3AF" />
    <SolidColorBrush x:Key="ButtonDisabledBorder" Color="#D8DDE5" />
    <SolidColorBrush x:Key="AccentPositive" Color="#16A34A" />
    <SolidColorBrush x:Key="AccentBlue" Color="#2563EB" />
    <SolidColorBrush x:Key="AccentDestructive" Color="#DC2626" />

    <!-- Lists -->
    <SolidColorBrush x:Key="ListBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ListBorder" Color="#D0D5DD" />

    <!-- Error/Warning -->
    <SolidColorBrush x:Key="ErrorBorder" Color="#EF4444" />
    <SolidColorBrush x:Key="ErrorBackground" Color="#FEE2E2" />
    <SolidColorBrush x:Key="ErrorText" Color="#991B1B" />

    <!-- Doctor status indicator -->
    <SolidColorBrush x:Key="StatusReadyFill" Color="#16A34A" />
    <SolidColorBrush x:Key="StatusWarningFill" Color="#D97706" />
    <SolidColorBrush x:Key="StatusNeutralFill" Color="#9CA3AF" />

    <!-- Menu system color overrides (WPF templates read these directly) -->
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}"          Color="#EAEAEA" />
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}"       Color="#EAEAEA" />
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}"      Color="#111827" />
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#D0D5DD" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#111827" />
    <!-- ToolTip system color overrides -->
    <SolidColorBrush x:Key="{x:Static SystemColors.InfoBrushKey}"          Color="#F8F9FB" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InfoTextBrushKey}"      Color="#111827" />

    <!-- Loading overlay -->
    <SolidColorBrush x:Key="OverlayBackdrop" Color="#88000000" />
    <SolidColorBrush x:Key="OverlayCard" Color="#F2FFFFFF" />
    <SolidColorBrush x:Key="OverlayForeground" Color="#111827" />
</ResourceDictionary>
