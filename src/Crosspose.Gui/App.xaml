<Application x:Class="Crosspose.Gui.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Crosspose.Gui"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Dark first, light last so light is the default -->
                <ResourceDictionary Source="Themes/Colors.Dark.xaml" />
                <ResourceDictionary Source="Themes/Colors.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Crosspose.Ui;component/GroupedListViewResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Menu items: colours come from system key overrides in theme files -->
            <Style TargetType="MenuItem">
                <Setter Property="Background" Value="{DynamicResource SidebarBackground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SidebarBackground}" />
                <Style.Triggers>
                    <Trigger Property="IsHighlighted" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SidebarBackground}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
            <!-- Opt-in accent colours via Tag="AccentPositive|AccentBlue|AccentDestructive".
                 MultiTrigger requires IsEnabled=True so disabled buttons keep the standard
                 disabled appearance (readable text, no washed-out accent colour). -->
            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Style.Triggers>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="Tag" Value="AccentPositive" />
                            <Condition Property="IsEnabled" Value="True" />
                        </MultiTrigger.Conditions>
                        <MultiTrigger.Setters>
                            <Setter Property="Background" Value="{DynamicResource AccentPositive}" />
                            <Setter Property="Foreground" Value="White" />
                        </MultiTrigger.Setters>
                    </MultiTrigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="Tag" Value="AccentBlue" />
                            <Condition Property="IsEnabled" Value="True" />
                        </MultiTrigger.Conditions>
                        <MultiTrigger.Setters>
                            <Setter Property="Background" Value="{DynamicResource AccentBlue}" />
                            <Setter Property="Foreground" Value="White" />
                        </MultiTrigger.Setters>
                    </MultiTrigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="Tag" Value="AccentDestructive" />
                            <Condition Property="IsEnabled" Value="True" />
                        </MultiTrigger.Conditions>
                        <MultiTrigger.Setters>
                            <Setter Property="Background" Value="{DynamicResource AccentDestructive}" />
                            <Setter Property="Foreground" Value="White" />
                        </MultiTrigger.Setters>
                    </MultiTrigger>
                </Style.Triggers>
            </Style>
            <local:StatusBrushConverter x:Key="StatusBrushConverter"/>
            <local:PlatformIconConverter x:Key="PlatformIconConverter"/>
            <SolidColorBrush x:Key="SuccessStrokeBrush" Color="#22c55e" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
