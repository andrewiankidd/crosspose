<Window x:Class="Crosspose.Gui.PortableModeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enable Portable Mode"
        Height="480"
        Width="600"
        MinWidth="520"
        MinHeight="400"
        Background="{DynamicResource WindowBackground}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Enable Portable Mode"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}"
                   Margin="0,0,0,8" />

        <!-- Description -->
        <Border Grid.Row="1"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderBrushColor}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12"
                Margin="0,0,0,12">
            <TextBlock TextWrapping="Wrap"
                       Foreground="{DynamicResource TextMuted}"
                       FontSize="12"
                       LineHeight="18">
                <Run>Portable mode stores all Crosspose data beside the application executable instead of in your user profile. This makes the installation self-contained and easy to move or back up.</Run>
                <LineBreak /><LineBreak />
                <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}">Data location will change:</Run>
                <LineBreak />
                <Run>  From:  %APPDATA%\crosspose\  (and %LOCALAPPDATA%\Crosspose\)</Run>
                <LineBreak />
                <Run>  To:      .\AppData\crosspose\  (beside Crosspose.exe)</Run>
                <LineBreak /><LineBreak />
                <Run>Choose which existing data to move. Unchecked items are left in place and will no longer be used once portable mode is active.</Run>
            </TextBlock>
        </Border>

        <!-- Data items checklist -->
        <Border Grid.Row="2"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderBrushColor}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="4"
                Margin="0,0,0,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ItemsList" ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6"
                                    BorderBrush="{DynamicResource BorderBrushColor}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding ShouldMigrate}"
                                              IsEnabled="{Binding CanMigrate}"
                                              VerticalAlignment="Top"
                                              Margin="0,2,10,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontWeight="SemiBold"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextPrimary}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CanMigrate}" Value="False">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="{Binding Name}" />
                                            <Run Text=" " />
                                            <Run FontWeight="Normal" FontStyle="Italic">
                                                <Run.Style>
                                                    <Style TargetType="Run">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanMigrate}" Value="True">
                                                                <Setter Property="Text" Value="" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding CanMigrate}" Value="False">
                                                                <Setter Property="Text" Value="(not found — nothing to move)" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Run.Style>
                                            </Run>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   Margin="0,1,0,3"
                                                   TextWrapping="Wrap" />
                                        <TextBlock FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontFamily="Consolas"
                                                   TextWrapping="Wrap">
                                            <Run Text="{Binding SourcePath}" />
                                            <Run Text=" → " />
                                            <Run Text="{Binding DestPath}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="90"
                    Height="30"
                    Margin="0,0,8,0"
                    Background="{DynamicResource ButtonBackground}"
                    Foreground="{DynamicResource ButtonForeground}"
                    BorderBrush="{DynamicResource ButtonBorder}"
                    Click="OnCancelClick" />
            <Button Content="Enable Portable Mode"
                    Height="30"
                    Padding="16,0"
                    Background="{DynamicResource AccentPositive}"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="OnConfirmClick" />
        </StackPanel>
    </Grid>
</Window>
