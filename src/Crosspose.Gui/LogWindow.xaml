<Window x:Class="Crosspose.Gui.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log View"
        Height="400"
        Width="700"
        MinWidth="500"
        WindowStartupLocation="CenterOwner"
        Loaded="OnLoaded"
        Closing="OnClosing">
    <Grid Margin="12" Background="{DynamicResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Content="Clear" Padding="8,3" Margin="8,0,0,0" Click="OnClear" />
            <TextBlock DockPanel.Dock="Left" Text="Filter:" VerticalAlignment="Center"
                       Margin="0,0,6,0" Foreground="{DynamicResource TextMuted}" />
            <TextBox x:Name="FilterBox"
                     TextChanged="OnFilterChanged"
                     Padding="6,3"
                     Background="{DynamicResource InputBackground}"
                     Foreground="{DynamicResource TextPrimary}"
                     BorderBrush="{DynamicResource InputBorder}" />
        </DockPanel>
        <TextBox x:Name="LogBox"
                 Grid.Row="1"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Background="{DynamicResource InputBackground}"
                 Foreground="{DynamicResource TextPrimary}"
                 BorderBrush="{DynamicResource InputBorder}"
                 FontFamily="Consolas"
                 FontSize="12" />
    </Grid>
</Window>
