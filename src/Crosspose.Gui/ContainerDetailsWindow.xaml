<Window x:Class="Crosspose.Gui.ContainerDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Crosspose.Ui;assembly=Crosspose.Ui"
        xmlns:ic="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
        Height="640"
        Width="960"
        MinWidth="720"
        MinHeight="480"
        Background="{DynamicResource WindowBackground}"
        WindowStartupLocation="CenterOwner">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="12,12,12,6">
            <TextBlock Text="{Binding Id}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />

            <!-- Image label — view mode -->
            <StackPanel x:Name="ImageViewPanel" Orientation="Horizontal" Margin="0,2,0,0">
                <TextBlock x:Name="ImageViewLabel" Text="{Binding Image}"
                           Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" />
                <Button x:Name="EditImageBtn" Margin="6,0,0,0" Padding="2,1"
                        BorderThickness="0" Background="Transparent"
                        ToolTip="Change image tag" Click="OnEditImageStart"
                        VerticalAlignment="Center" Cursor="Hand">
                    <ic:FluentIcon Icon="Edit" IconVariant="Regular" IconSize="Size12"
                                   Width="12" Height="12" Foreground="{DynamicResource TextMuted}" />
                </Button>
            </StackPanel>

            <!-- Image label — edit mode -->
            <Grid x:Name="ImageEditPanel" Visibility="Collapsed" Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="280" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ImageTagCombo" Grid.Column="0" IsEditable="True"
                          IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                          MinWidth="280"
                          Background="{DynamicResource InputBackground}"
                          Foreground="{DynamicResource TextPrimary}"
                          BorderBrush="{DynamicResource InputBorder}"
                          VerticalContentAlignment="Center" Padding="4,2" />
                <TextBlock x:Name="TagFetchStatus" Grid.Column="1" Margin="8,0"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}" FontSize="11" />
                <Button x:Name="SaveTagBtn" Grid.Column="2" Margin="4,0,0,0" Padding="6,2"
                        Click="OnImageTagSave" ToolTip="Apply tag change" IsEnabled="False"
                        Background="{DynamicResource ButtonBackground}"
                        Foreground="{DynamicResource ButtonForeground}"
                        BorderBrush="{DynamicResource ButtonBorder}">
                    <ic:FluentIcon Icon="Checkmark" IconVariant="Regular" IconSize="Size16" Width="16" Height="16" />
                </Button>
                <Button Grid.Column="3" Margin="4,0,0,0" Padding="6,2"
                        Click="OnImageTagCancel" ToolTip="Cancel"
                        Background="{DynamicResource ButtonBackground}"
                        Foreground="{DynamicResource ButtonForeground}"
                        BorderBrush="{DynamicResource ButtonBorder}">
                    <ic:FluentIcon Icon="Dismiss" IconVariant="Regular" IconSize="Size16" Width="16" Height="16" />
                </Button>
            </Grid>

            <TextBlock Text="{Binding Status}" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0" />
        </StackPanel>

        <TabControl x:Name="DetailTabControl" Margin="12,6,12,12"
                    Background="{DynamicResource PanelBackground}"
                    Foreground="{DynamicResource TextPrimary}"
                    SelectionChanged="OnTabSelectionChanged">

            <!-- ═══ Logs ═══ -->
            <TabItem Header="Logs">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="Refresh logs" Padding="8,4" Click="OnRefreshLogs"
                                Background="{DynamicResource ButtonBackground}"
                                Foreground="{DynamicResource ButtonForeground}"
                                BorderBrush="{DynamicResource ButtonBorder}" />
                        <TextBlock x:Name="LogsStatus" Margin="10,0,0,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMuted}" />
                    </StackPanel>
                    <Grid Grid.Row="1">
                        <TextBox x:Name="LogsText" IsReadOnly="True" AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 Background="{DynamicResource InputBackground}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource InputBorder}"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto" />
                        <ui:LoadingOverlay x:Name="LogsOverlay" Visibility="Collapsed" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══ Inspect ═══ -->
            <TabItem Header="Inspect">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="Refresh" Padding="8,4" Click="OnRefreshInspect"
                                Background="{DynamicResource ButtonBackground}"
                                Foreground="{DynamicResource ButtonForeground}"
                                BorderBrush="{DynamicResource ButtonBorder}" />
                        <TextBlock x:Name="InspectStatus" Margin="10,0,0,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMuted}" />
                    </StackPanel>
                    <Grid Grid.Row="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,2,0,8">
                                <TextBlock Text="OVERVIEW" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMuted}" Margin="2,0,0,4" />
                                <ListView x:Name="InspectOverviewList" MaxHeight="152"
                                          Background="{DynamicResource InputBackground}"
                                          Foreground="{DynamicResource TextPrimary}"
                                          BorderBrush="{DynamicResource InputBorder}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Property" DisplayMemberBinding="{Binding Key}" Width="180" />
                                            <GridViewColumn Header="Value" DisplayMemberBinding="{Binding Value}" Width="600" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>

                                <TextBlock Text="ENVIRONMENT" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMuted}" Margin="2,12,0,4" />
                                <ListView x:Name="EnvVarsList" MaxHeight="200"
                                          Background="{DynamicResource InputBackground}"
                                          Foreground="{DynamicResource TextPrimary}"
                                          BorderBrush="{DynamicResource InputBorder}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Variable" DisplayMemberBinding="{Binding Key}" Width="260" />
                                            <GridViewColumn Header="Value" DisplayMemberBinding="{Binding Value}" Width="520" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>

                                <TextBlock Text="PORTS" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMuted}" Margin="2,12,0,4" />
                                <ListView x:Name="InspectPortsList" MaxHeight="120"
                                          Background="{DynamicResource InputBackground}"
                                          Foreground="{DynamicResource TextPrimary}"
                                          BorderBrush="{DynamicResource InputBorder}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Container Port" DisplayMemberBinding="{Binding Key}" Width="160" />
                                            <GridViewColumn Header="Host Binding" DisplayMemberBinding="{Binding Value}" Width="620" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>

                                <TextBlock Text="LABELS" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMuted}" Margin="2,12,0,4" />
                                <ListView x:Name="LabelsList" MaxHeight="200"
                                          Background="{DynamicResource InputBackground}"
                                          Foreground="{DynamicResource TextPrimary}"
                                          BorderBrush="{DynamicResource InputBorder}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Label" DisplayMemberBinding="{Binding Key}" Width="260" />
                                            <GridViewColumn Header="Value" DisplayMemberBinding="{Binding Value}" Width="520" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </StackPanel>
                        </ScrollViewer>
                        <ui:LoadingOverlay x:Name="InspectLoadingOverlay" Visibility="Collapsed" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══ Bind mounts ═══ -->
            <TabItem Header="Bind mounts">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="MountsStatus" Margin="0,0,0,6" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMuted}" />
                    <Grid Grid.Row="1">
                        <ListView x:Name="MountsList"
                                  Background="{DynamicResource InputBackground}"
                                  Foreground="{DynamicResource TextPrimary}"
                                  BorderBrush="{DynamicResource InputBorder}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Type}" Width="64" />
                                    <GridViewColumn Header="Source" DisplayMemberBinding="{Binding Source}" Width="300" />
                                    <GridViewColumn Header="Destination" DisplayMemberBinding="{Binding Destination}" Width="280" />
                                    <GridViewColumn Header="Mode" DisplayMemberBinding="{Binding Mode}" Width="64" />
                                    <GridViewColumn Header="RW" DisplayMemberBinding="{Binding RwLabel}" Width="40" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                        <ui:LoadingOverlay x:Name="MountsLoadingOverlay" Visibility="Collapsed" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══ Exec ═══ -->
            <TabItem Header="Exec">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBox x:Name="ExecCommandBox" Width="420" Padding="6,4"
                                 Background="{DynamicResource InputBackground}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource InputBorder}"
                                 VerticalContentAlignment="Center"
                                 KeyDown="OnExecCommandKeyDown" />
                        <Button Content="Run" Padding="12,4" Margin="6,0,0,0" Click="OnExecRun"
                                Background="{DynamicResource ButtonBackground}"
                                Foreground="{DynamicResource ButtonForeground}"
                                BorderBrush="{DynamicResource ButtonBorder}" />
                        <Button Content="Clear" Padding="8,4" Margin="4,0,0,0" Click="OnExecClear"
                                Background="{DynamicResource ButtonBackground}"
                                Foreground="{DynamicResource ButtonForeground}"
                                BorderBrush="{DynamicResource ButtonBorder}" />
                        <TextBlock x:Name="ExecStatus" Margin="10,0,0,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMuted}" />
                    </StackPanel>
                    <TextBox x:Name="ExecOutput" Grid.Row="1"
                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                             Background="{DynamicResource InputBackground}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource InputBorder}"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" />
                </Grid>
            </TabItem>

            <!-- ═══ Files (future) ═══ -->
            <TabItem Header="Files">
                <TextBlock Text="File browser coming soon." Padding="8"
                           Foreground="{DynamicResource TextMuted}" />
            </TabItem>

            <!-- ═══ Stats ═══ -->
            <TabItem Header="Stats">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="Refresh" Padding="8,4" Click="OnRefreshStats"
                                Background="{DynamicResource ButtonBackground}"
                                Foreground="{DynamicResource ButtonForeground}"
                                BorderBrush="{DynamicResource ButtonBorder}" />
                        <TextBlock x:Name="StatsStatus" Margin="10,0,0,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMuted}" />
                    </StackPanel>
                    <Grid Grid.Row="1">
                        <ListView x:Name="StatsList"
                                  Background="{DynamicResource InputBackground}"
                                  Foreground="{DynamicResource TextPrimary}"
                                  BorderBrush="{DynamicResource InputBorder}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Metric" DisplayMemberBinding="{Binding Key}" Width="200" />
                                    <GridViewColumn Header="Value" DisplayMemberBinding="{Binding Value}" Width="600" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                        <ui:LoadingOverlay x:Name="StatsLoadingOverlay" Visibility="Collapsed" />
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
